  tensor_parallel_size: 4
  tokenizer_path: /data/models/Qwen3.5-35B-A3B

serve:
  trust_remote_code: true
  extra_args: ""

sglang:
  dtype: bfloat16
  mem_fraction_static: 0.50
  extra_args: "--skip-server-warmup --max-total-tokens 4096"

benchmark:
