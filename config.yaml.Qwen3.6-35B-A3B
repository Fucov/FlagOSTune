model:
  path: /data/models/Qwen3.6-35B-A3B
  name: Qwen3.6-35B-A3B
  tensor_parallel_size: 4
  tokenizer_path: null

serve:
  gpu_memory_utilization: 0.85
  max_num_batched_tokens: 16384
  max_num_seqs: 2048
  trust_remote_code: true
  reasoning_parser: qwen3
  load_format: auto
  extra_args: "--max-model-len 65536 --no-enable-prefix-caching"

sglang:
  dtype: bfloat16
  mem_fraction_static: 0.80
  context_length: 65536
  load_format: auto
  extra_args: "--skip-server-warmup --max-total-tokens 65536 --disable-cuda-graph --attention-backend triton"

benchmark:
  dataset_name: random
  dataset_path: /data/yangkw/datasets/sharegpt_synthetic_2048.json
  host: 127.0.0.1
  port_base: 2345
  num_runs: 3
  scenarios:
    optimized:
      - name: p32768d1024_c1
        input_len: 32768
        output_len: 1024
        concurrency: 1
      - name: p4096d4096_c8
        input_len: 4096
        output_len: 4096
        concurrency: 8
      - name: p1024d1024_c32
        input_len: 1024
        output_len: 1024
        concurrency: 32
    full:
      - name: p128d128_c64
        input_len: 128
        output_len: 128
        concurrency: 64
      - name: p2048d1024_c32
        input_len: 2048
        output_len: 1024
        concurrency: 32
      - name: p4096d4096_c8
        input_len: 4096
        output_len: 4096
        concurrency: 8
      - name: p32768d1024_c1
        input_len: 32768
        output_len: 1024
        concurrency: 1

target_ops:
  - reciprocal
  - cat
  - gather
  - lt
  - le
  - softmax
  - scatter
  - cumsum_out
  - layer_norm

paths:
  results: /data/yangkw/outputs/flagostune_results
  reports: /data/yangkw/outputs/flagostune_reports
  gems_config: gems-config
  processing: processing
  use_model_name: true