model:
  name: Qwen3.6-35B-A3B-FP8-TP4-P32768D1024C64
  path: /data/models/Qwen3.6-35B-A3B-FP8
  tokenizer_path: /data/models/Qwen3.6-35B-A3B-FP8
  tensor_parallel_size: 4

runtime:
  backend: sglang
  device: cuda
  dtype: bfloat16

sglang:
  context_length: 65536
  mem_fraction_static: 0.80
  load_format: auto
  trust_remote_code: true
  extra_args: "--disable-cuda-graph --attention-backend triton --sampling-backend pytorch --watchdog-timeout 3600 --max-running-requests 2048 --chunked-prefill-size 16384 --max-prefill-tokens 16384 --port 30001 --nccl-port 29501 "

benchmark:
  dataset_name: sharegpt
  dataset_path: /data/yangkw/datasets/qwen_controlled/p32768d1024_c64.json
  num_runs: 2
  scenarios:
    optimized:
      - name: p32768d1024_c64
        input_len: 32768
        output_len: 1024
        concurrency: 64

output:
  result_dir: /data/yangkw/outputs/flagostune_results
  report_dir: /data/yangkw/outputs/flagostune_reports